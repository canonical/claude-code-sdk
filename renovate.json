{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "enabledManagers": [
    "custom.regex"
  ],
  "customDatasources": {
    "claude-code-stable": {
      "defaultRegistryUrlTemplate": "https://downloads.claude.ai/claude-code-releases/stable",
      "format": "plain"
    }
  },
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^VERSION$/"
      ],
      "matchStrings": [
        "(?<currentValue>[0-9.]+)"
      ],
      "depNameTemplate": "anthropics/claude-code",
      "datasourceTemplate": "custom.claude-code-stable",
      "versioningTemplate": "semver"
    }
  ],
  "baseBranchPatterns": [
    "latest"
  ],
  "packageRules": [
    {
      "matchPackageNames": [
        "anthropics/claude-code"
      ],
      "matchBaseBranches": [
        "latest"
      ]
    }
  ]
}
