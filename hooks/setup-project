#!/usr/bin/bash

mkdir -p /home/workshop/.claude

# Install the SDK's workshop prompt only on first run. Once .workshop-prompt.md
# exists — whether unchanged from the SDK or user-customised — refreshes leave
# it alone. To pull in an updated SDK prompt, delete the file and refresh.
if [[ ! -f "/home/workshop/.claude/.workshop-prompt.md" ]]; then
    cp "${SDK}/workshop-prompt.md" "/home/workshop/.claude/.workshop-prompt.md"
fi
