mkdir -p "$HOME/.claude"

# Install the SDK's CLAUDE.md only on first run. Once it exists — whether
# unchanged from the SDK or user-customised — refreshes leave it alone.
# To pull in an updated SDK prompt, delete the file and run `workshop refresh`.
#
# Claude Code reads ~/.claude/CLAUDE.md natively as global user memory on
# every invocation (see code.claude.com/docs/en/memory), so no wrapper or
# --append-system-prompt flag is needed.
if [[ ! -f "$HOME/.claude/CLAUDE.md" ]]; then
    install -m644 "${SDK}/workshop-prompt.md" "$HOME/.claude/CLAUDE.md"
fi
