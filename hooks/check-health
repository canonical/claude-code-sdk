if [[ ! -f "${SDK}/bin/claude" ]]; then
  workshopctl set-health --code="claude-not-installed" error "Claude Code not installed."
  exit 0
fi

if ! sudo -u workshop --login which claude >/dev/null 2>&1; then
  workshopctl set-health --code="claude-not-on-path" error "Claude Code not available on the \$PATH."
  exit 0
fi

workshopctl set-health okay
